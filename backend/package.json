{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --target bun --outfile dist/index.js && bun build ./src/scripts/ingest.ts --target bun --outfile dist/ingest.js",
    "start": "bun run dist/index.js",
    "ingest": "bun run dist/ingest.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "0.31.9"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@t3-oss/env-core": "0.13.10",
    "drizzle-orm": "0.45.1",
    "elysia": "1.4.27",
    "fast-xml-parser": "5.4.1",
    "postgres": "3.4.8",
    "zod": "4.3.6"
  }
}
